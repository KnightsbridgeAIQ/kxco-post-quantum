{
  "name": "kxco-post-quantum",
  "version": "1.0.2",
  "description": "Production-tested post-quantum cryptography patterns: deterministic key derivation, hybrid webhook signing, and kid fingerprinting. Built on @noble/post-quantum. Used in production at KXCO.",
  "keywords": [
    "post-quantum",
    "pqc",
    "ml-dsa",
    "ml-kem",
    "dilithium",
    "kyber",
    "nist",
    "fips-203",
    "fips-204",
    "webhook-signing",
    "quantum-resistant",
    "armature"
  ],
  "license": "MIT",
  "author": "KXCO by Knightsbridge <hello@kxco.ai>",
  "homepage": "https://kxco.ai",
  "funding": "https://kxco.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/JackKXCO/kxco-post-quantum.git"
  },
  "bugs": {
    "url": "https://github.com/JackKXCO/kxco-post-quantum/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types":  "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./ml-dsa": {
      "types":  "./src/ml-dsa.d.ts",
      "import": "./src/ml-dsa.js"
    },
    "./ml-kem": {
      "types":  "./src/ml-kem.d.ts",
      "import": "./src/ml-kem.js"
    },
    "./derive": {
      "types":  "./src/derive.d.ts",
      "import": "./src/derive.js"
    },
    "./webhook": {
      "types":  "./src/webhook.d.ts",
      "import": "./src/webhook.js"
    },
    "./kid": {
      "types":  "./src/kid.d.ts",
      "import": "./src/kid.js"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.2.1"
  },
  "scripts": {
    "test":             "node --test test/basic.test.js && node test/run-vectors.js",
    "test:vectors":     "node test/run-vectors.js",
    "generate:vectors": "node test/generate-vectors.js > test/vectors.json"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  }
}
